{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlayForge",
  "version": "0.1.0",
  "identifier": "com.playforge.app",
  "build": {
    "beforeDevCommand": "npm run start -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/playforge/browser"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "**/.*", "**/.*/**", "/**", "/**/.*", "/**/.*/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "windows": {
      "wix": {
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      },
      "nsis": {
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "PlayForge",
        "compression": "lzma"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hakanbaban53/PlayForge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwREQ4ODk2Rjk0NjgzM0IKUldRN2cwYjVsb2pkc0g1bUYwU3BGdmU0NlVzdUk4dk1EUWpzK1dFR0QwcE11VVEyNmFtaDlBMnQK"
    }
  }
}
